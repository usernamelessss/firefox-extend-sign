{
  "manifest_version": 3,
  "name": "regex-search-anymore",
  "version": "0.1.6",
  "description": "Search page content using JS RegExps",
  "icons": {
    "48": "icons/48x48.png",
    "64": "icons/default-64.png",
    "96": "icons/96x96.png",
    "128": "icons/128x128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "regex-search-anymore@usernameless",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "permissions": [
    "activeTab"
  ],
  "action": {
    "default_icon": "icons/default-64.png",
    "default_title": "Regex Search",
    "default_popup": "popup.html"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+F",
        "mac": "Command+Shift+F"
      },
      "description": "Activate the plugin to start the search"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}

